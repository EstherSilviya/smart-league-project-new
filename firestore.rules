rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ─── GLOBAL READ ACCESS (To fix permission errors) ───
    match /{document=**} {
      allow read: if true;
    }

    // ─── HELPER FUNCTIONS ───
    function isAuthenticated() { return request.auth != null; }
    function hasRole(roles) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in roles;
    }

    // ─── WRITE RULES ───
    match /users/{userId} {
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid == userId || hasRole(['admin', 'management', 'administrator']));
      allow delete: if hasRole(['admin', 'management', 'administrator']);
    }

    match /students/{id} { allow write: if hasRole(['editor', 'management', 'administrator', 'admin', 'teacher']); }
    match /news/{id} { allow write: if hasRole(['editor', 'management', 'administrator', 'admin', 'teacher']); }
    match /achievements/{id} { allow write: if hasRole(['editor', 'management', 'administrator', 'admin', 'teacher']); }
    match /events/{id} { allow write: if hasRole(['editor', 'management', 'administrator', 'admin', 'teacher']); }
    match /achievementCriteria/{id} { allow write: if hasRole(['management', 'administrator', 'admin']); }
    
    match /invites/{id} {
      allow update: if true;
      allow create, delete: if hasRole(['management', 'administrator', 'admin']);
    }

    match /tempInviteTokens/{id} {
      allow delete: if true;
      allow create: if hasRole(['management', 'administrator', 'admin']);
    }
  }
}
